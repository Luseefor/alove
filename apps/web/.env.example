# --- Runtime mode ---
# true/1 = local standalone (no Clerk/Convex); false/0 = cloud/auth mode.
NEXT_PUBLIC_LOCAL_STANDALONE=true
# Editor mode for the active latex-ide editor surface.
# Default is codemirror. Options: codemirror, textarea.
# Rollback path: set NEXT_PUBLIC_EDITOR_MODE=textarea.
# Next.js injects NEXT_PUBLIC_* for client bundles at build/start time; rebuild/restart
# after changing these flags to validate the other editor path.
NEXT_PUBLIC_EDITOR_MODE=codemirror
# Legacy compatibility flag (deprecated; kept for backward compatibility):
# NEXT_PUBLIC_ENABLE_CODEMIRROR_EDITOR=true
# Starting port for local dev scan (30129-30130 reserved for e2e tests).
ALOVE_WEB_PORT=30127

# --- Clerk (auth) ---
# https://dashboard.clerk.com — create application, copy keys into apps/web/.env.local
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Convex (realtime files + presence + design mode) ---
# From repo root: bun run convex:dev (or cd apps/web && bunx convex dev) — writes NEXT_PUBLIC_CONVEX_URL into .env.local
NEXT_PUBLIC_CONVEX_URL=

# Issuer domain for Convex JWT validation (Clerk → JWT template named "convex")
# Example: https://your-instance.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=

# --- Compile queue ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Compile worker ---
WORKER_CONCURRENCY=2
COMPILE_USE_DOCKER=true
COMPILE_DOCKER_IMAGE=ghcr.io/xu-cheng/texlive-full:latest
COMPILE_DOCKER_PLATFORM=
COMPILE_TIMEOUT_MS=120000
COMPILE_MAX_FILES=250
COMPILE_MAX_FILE_BYTES=1048576
COMPILE_MAX_TOTAL_BYTES=10485760
COMPILE_MAX_LOG_BYTES=262144
COMPILE_MAX_PDF_BYTES=52428800

# --- Optional: legacy Hocuspocus + Yjs (superseded by Convex in this app) ---
# NEXT_PUBLIC_COLLAB_URL=ws://127.0.0.1:1234
# NEXT_PUBLIC_COLLAB_ROOM=alove-demo
# PORT=1234
# QUIET=false
