# --- Local standalone (no Clerk / Convex / collab) ---
# Set to true for offline editor + compile; default `bun run dev` enables this via scripts/dev-standalone.ts.
# NEXT_PUBLIC_LOCAL_STANDALONE=true
# Prefer a starting port for the dev server scan (optional; default 30127).
# ALOVE_WEB_PORT=30127

# --- Clerk (auth) ---
# https://dashboard.clerk.com — create application, copy keys into apps/web/.env.local
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Convex (realtime files + presence + design mode) ---
# From repo root: bun run convex:dev (or cd apps/web && bunx convex dev) — writes NEXT_PUBLIC_CONVEX_URL into .env.local
NEXT_PUBLIC_CONVEX_URL=

# Issuer domain for Convex JWT validation (Clerk → JWT template named "convex")
# Example: https://your-instance.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=

# --- Compile queue ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Optional: legacy Hocuspocus + Yjs (superseded by Convex in this app) ---
# NEXT_PUBLIC_COLLAB_URL=ws://127.0.0.1:1234
# NEXT_PUBLIC_COLLAB_ROOM=alove-demo
