{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun ./scripts/dev-standalone.ts",
    "dev:cloud": "next dev --turbopack -p 3000",
    "dev:with-convex": "concurrently -n convex,next -c blue,green \"convex dev\" \"next dev --turbopack -p 3000\"",
    "convex:dev": "convex dev",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint . && bun ./scripts/check-design-tokens.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:build:default": "rm -rf .next && NEXT_PUBLIC_LOCAL_STANDALONE=true next build",
    "e2e:build:cm": "rm -rf .next && NEXT_PUBLIC_LOCAL_STANDALONE=true NEXT_PUBLIC_ENABLE_CODEMIRROR_EDITOR=true next build",
    "e2e:default": "bun run e2e:build:default && E2E_CODEMIRROR=0 playwright test",
    "e2e:cm": "bun run e2e:build:cm && E2E_CODEMIRROR=1 playwright test",
    "e2e:build:prod-default": "rm -rf .next && NEXT_PUBLIC_LOCAL_STANDALONE=true next build --turbopack",
    "e2e:build:prod-cm": "rm -rf .next && NEXT_PUBLIC_LOCAL_STANDALONE=true NEXT_PUBLIC_ENABLE_CODEMIRROR_EDITOR=true next build --turbopack",
    "e2e:prod-default": "bun run e2e:build:prod-default && E2E_CODEMIRROR=0 playwright test",
    "e2e:prod-cm": "bun run e2e:build:prod-cm && E2E_CODEMIRROR=1 playwright test"
  },
  "dependencies": {
    "@alove/editor": "workspace:*",
    "@alove/protocol": "workspace:*",
    "@alove/queue": "workspace:*",
    "@clerk/nextjs": "^7.2.5",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.5",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "bullmq": "^5.47.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "convex": "^1.36.0",
    "ioredis": "^5.6.0",
    "lucide-react": "^1.11.0",
    "next": "15.5.15",
    "pdfjs-dist": "^5.6.205",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^2.1.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/eslint-plugin-next": "15.5.15",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfjs-dist": "^2.10.378",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
